# ====== Jama MCP Server environment ======
# Copy to ".env" and fill in. All values are read by config.py.

# --- Jama REST API ---
JAMA_URL=https://your-tenant.jamacloud.com
JAMA_CLIENT_ID=your-jama-client-id
JAMA_CLIENT_SECRET=your-jama-client-secret
JAMA_API_PREFIX=/rest/latest
JAMA_PAGE_SIZE=50
JAMA_PAGE_DELAY=0.25

# --- Embedding provider ---
# "local" (default): runs bge-small-en-v1.5 on CPU via fastembed/ONNX. No API
# key, no network at query time; model downloads once (China mirror first).
# "azure": calls an OpenAI-compatible embedding endpoint (set the Azure vars
# below and switch EMBEDDING_PROVIDER=azure).
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-en-v1.5
# Cap ONNX CPU threads at this % of system cores (default 60).
EMBEDDING_CPU_PERCENT=60
# Min download throughput (bytes/s) for the model mirror speed test.
EMBEDDING_DOWNLOAD_MIN_BPS=200000
# Texts per embedding batch (local CPU: 32 keeps latency low).
EMBEDDING_BATCH_SIZE=32
# Concurrent embedding requests (local is CPU-bound, forced to 1; azure: 2).
EMBEDDING_CONCURRENCY=2

# --- Azure embedding (only used when EMBEDDING_PROVIDER=azure) ---
EMBEDDING_BASE_URL=https://your-embedding-endpoint.example.com
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_KEY_HEADER=api-key
EMBEDDING_TIMEOUT=60

# --- Local cross-encoder reranker (CPU, ONNX via fastembed) ---
# Default: cross-encoder/ms-marco-MiniLM-L-6-v2 (~80MB). This torch-style name
# is transparently remapped to its ONNX port (Xenova/ms-marco-MiniLM-L-6-v2)
# at load time, so it runs on onnxruntime via fastembed — no torch/transformers
# dependency (eliminating the Windows c10.dll/WinError 1114 load failure).
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ALLOW_FALLBACK=1

# --- Storage (defaults to project-local user/ folder) ---
JAMA_MCP_DB_PATH=user/jama_mcp.db
SQLITE_BUSY_TIMEOUT_MS=5000

# --- Incremental sync ---
SYNC_ENABLED=1
SYNC_INTERVAL_HOURS=2
# Concurrent page fetches during a project download (Jama caps pages at 50).
SYNC_DOWNLOAD_CONCURRENCY=16

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=80

# --- MCP transport ---
# stdio (default): MCP client launches the server as a subprocess (local use).
# streamable-http: server listens on a port; clients connect via HTTP — the MCP
#                  new standard. Use for remote access or Docker.
# sse:             server-sent events transport, for older MCP clients.
JAMA_MCP_TRANSPORT=stdio
# JAMA_MCP_HOST=127.0.0.1   # set 0.0.0.0 for remote/Docker access
# JAMA_MCP_PORT=8000
